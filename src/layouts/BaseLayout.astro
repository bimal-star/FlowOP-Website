---
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description: string;
  /** Current path for nav highlighting, e.g. '/' or '/about' */
  pathname: string;
  /** e.g. `contact-page` for contact form styling */
  bodyClass?: string | undefined;
}

const { title, description, pathname, bodyClass } = Astro.props;

const tickerSegments: { kind: 'phrase' | 'tool'; text: string }[] = [
  { kind: 'phrase', text: 'AI-augmented delivery' },
  { kind: 'phrase', text: 'Vibe coding' },
  { kind: 'phrase', text: 'Modern tools, practical outcomes' },
  { kind: 'phrase', text: 'Beyond the spreadsheet' },
  { kind: 'tool', text: 'Claude' },
  { kind: 'tool', text: 'ChatGPT' },
  { kind: 'tool', text: 'Copilot' },
  { kind: 'tool', text: 'Lovable' },
  { kind: 'tool', text: 'Cursor' },
  { kind: 'tool', text: 'Replit' },
  { kind: 'phrase', text: 'Operations meets AI' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Analytics />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class={bodyClass ? bodyClass : undefined}>
    <header class="site-nav">
      <div class="container nav-inner">
        <a href="/" class="nav-logo" aria-label="FlowOP home">
          <img src="/assets/Logo.png" alt="FlowOP logo" />
        </a>

        <button class="mobile-toggle" type="button" data-nav-toggle aria-label="Toggle menu" aria-expanded="false">
          <span></span>
        </button>

        <nav class="nav-links" data-nav-links>
          <a class:list={[{ active: pathname === '/' }]} href="/">Home</a>
          <a class:list={[{ active: pathname === '/services' }]} href="/services">Services</a>
          <a class:list={[{ active: pathname === '/experience' }]} href="/experience">Experience</a>
          <a class:list={[{ active: pathname === '/about' }]} href="/about">About</a>
          <a class:list={[{ active: pathname === '/contact' }]} href="/contact">Contact</a>
          <a class="nav-workspace" href="https://app.flowopsolutions.co.uk" target="_blank" rel="noopener noreferrer">Workspace</a>
        </nav>
      </div>
    </header>

    <slot />

    <div class="site-ticker" aria-label="Tools and delivery themes">
      <div class="site-ticker-viewport">
        <div class="site-ticker-track">
          <span class="site-ticker-content">
            {
              tickerSegments.map((seg, i) => (
                <>
                  {i > 0 ? <span class="ticker-sep" aria-hidden="true">✦</span> : null}
                  <span class={seg.kind === 'tool' ? 'ticker-tool' : 'ticker-phrase'}>{seg.text}</span>
                </>
              ))
            }
          </span>
          <span class="site-ticker-content" aria-hidden="true">
            {
              tickerSegments.map((seg, i) => (
                <>
                  {i > 0 ? <span class="ticker-sep" aria-hidden="true">✦</span> : null}
                  <span class={seg.kind === 'tool' ? 'ticker-tool' : 'ticker-phrase'}>{seg.text}</span>
                </>
              ))
            }
          </span>
        </div>
      </div>
    </div>

    <footer class="site-footer">
      <div class="container footer-inner">
        <a href="/" class="footer-logo" aria-label="FlowOP home">
          <img src="/assets/Logo.png" alt="" />
        </a>
        <p class="footer-copy">© <span data-year></span> FlowOP Solutions. All rights reserved.</p>
      </div>
    </footer>

    <script is:inline src="/js/main.js"></script>
  </body>
</html>
