---
interface Props {
  title: string;
  description: string;
  /** Current path for nav highlighting, e.g. '/' or '/about' */
  pathname: string;
  /** e.g. `contact-page` for contact form styling */
  bodyClass?: string | undefined;
}

const { title, description, pathname, bodyClass } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Consent Mode defaults (must run before gtag config / gtag.js) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        functionality_storage: 'denied',
        personalization_storage: 'denied',
        security_storage: 'granted',
      });
    </script>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-TGZS0VJQJR"></script>
    <script is:inline>
      gtag('js', new Date());
      gtag('config', 'G-TGZS0VJQJR');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class={bodyClass ? bodyClass : undefined}>
    <header class="site-nav">
      <div class="container nav-inner">
        <a href="/" class="nav-logo" aria-label="FlowOP home">
          <img src="/assets/Logo.png" alt="FlowOP logo" />
        </a>

        <button class="mobile-toggle" type="button" data-nav-toggle aria-label="Toggle menu" aria-expanded="false">
          <span></span>
        </button>

        <nav class="nav-links" data-nav-links>
          <a class:list={[{ active: pathname === '/' }]} href="/">Home</a>
          <a class:list={[{ active: pathname === '/services' }]} href="/services">Services</a>
          <a class:list={[{ active: pathname === '/about' }]} href="/about">About</a>
          <a class:list={[{ active: pathname === '/contact' }]} href="/contact">Contact</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="container footer-inner">
        <a href="/" class="footer-logo" aria-label="FlowOP home">
          <img src="/assets/Logo.png" alt="" />
        </a>
        <p class="footer-copy">© <span data-year></span> FlowOP Solutions. All rights reserved.</p>
      </div>
    </footer>

    <div
      id="cookie-consent"
      class="cookie-consent"
      role="dialog"
      aria-labelledby="cookie-consent-title"
      aria-describedby="cookie-consent-desc"
      aria-modal="false"
      hidden
    >
      <div class="cookie-consent-inner">
        <p id="cookie-consent-title" class="cookie-consent-heading">Analytics cookies</p>
        <p id="cookie-consent-desc" class="cookie-consent-text">
          We use Google Analytics to understand how the site is used. Analytics only runs if you accept. You can change
          your mind anytime by clearing site data for this domain.
        </p>
        <div class="cookie-consent-actions">
          <button type="button" class="cookie-consent-btn cookie-consent-btn--primary" data-consent-accept>
            Accept analytics
          </button>
          <button type="button" class="cookie-consent-btn cookie-consent-btn--ghost" data-consent-reject>
            Reject non-essential
          </button>
        </div>
      </div>
    </div>

    <script is:inline src="/js/main.js"></script>
  </body>
</html>
